rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Core Auth Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Basic file validation
    function isValidMedia() {
      return request.resource.contentType.matches('image/.*') || 
             request.resource.contentType.matches('video/.*') ||
             request.resource.contentType.matches('audio/.*');
    }

    function isValidSize() {
      // 50MB limit for general users
      return request.resource.size < 50 * 1024 * 1024;
    }

    match /users/{userId}/{allPaths=**} {
      // Users can only read/write their own directory
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId 
                   && isValidMedia() 
                   && isValidSize();
    }
    
    match /projects/{projectId}/{allPaths=**} {
      // In a real implementation, you'd check Firestore for project membership here
      // via firestore.get(), but that is complex in storage rules.
      // We rely on obfuscated paths and frontend App Check.
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidMedia() && isValidSize();
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
